# ── App URL (used by the Landing Page CTA button) ──────────────────────────
# Set this to the URL where the app is deployed (or leave as /home for local dev)
VITE_APP_URL=/home

# ── Cloudinary Upload Widget ────────────────────────────────────────────────
# Get these from your Cloudinary dashboard: https://cloudinary.com/console
# The upload preset must be set to "Unsigned" mode
VITE_CLOUDINARY_CLOUD_NAME=cloudexample
# IMPORTANTE: NO es la API Key ni la API Secret.
# Es el nombre del Upload Preset que creas en:
# Cloudinary Dashboard → Settings → Upload → Upload presets → Add upload preset
# El preset DEBE estar en modo "Unsigned" para funcionar desde el navegador.
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset_name
